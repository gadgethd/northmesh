# MQTT Configuration
MQTT_BROKER=mqtt.meshcore.uk
MQTT_PORT=8883
MQTT_TLS=true

# Cloudflare Tunnel (get from Cloudflare Dashboard > Networks > Tunnels)
# Create a tunnel, add a public hostname (northmesh.co.uk) pointing to http://nginx:443
# Copy the tunnel token below
CLOUDFLARE_TUNNEL_TOKEN=

# Host for frontend WS URL
HOST=northmesh.co.uk
