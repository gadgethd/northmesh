# ─────────────────────────────────────────
#  NorthMesh — Environment Config
# ─────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to source control.

# ── MQTT broker ───────────────────────────────────────────────────────────────
# Internal docker network URL for MQTT WebSocket listener
MQTT_BROKER_URL=ws://mosquitto:9001

# For external broker (uncomment and edit):
# MQTT_BROKER_URL=wss://mqtt.meshcore.uk:9001

# ── Cloudflare Tunnel ─────────────────────────────────────────────────────────
# Get from: Cloudflare Zero Trust → Access → Tunnels → your tunnel → token
CLOUDFLARE_TUNNEL_TOKEN=

# ── App port ──────────────────────────────────────────────────────────────────
PORT=3001

# ── Allowed origins ───────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://northmesh.co.uk,https://www.northmesh.co.uk
